{% if answers.include_quality and answers.hooks %}
{% set _rfc_gate = answers.include_docs and ("python" in answers.languages or "node" in answers.languages or "go" in answers.languages or "rust" in answers.languages) %}
{% set _py_gates = answers.include_docs and "python" in answers.languages %}
{% set ns = namespace(b=["  - repo: https://github.com/pre-commit/pre-commit-hooks\n    rev: v6.0.0\n    hooks:\n      - id: trailing-whitespace\n      - id: end-of-file-fixer\n      - id: check-yaml\n      - id: check-toml\n      - id: check-merge-conflict\n      - id: check-added-large-files\n        args: [--maxkb=4096]\n"]) %}
{% if answers.include_security %}{% set ns.b = ns.b + ["  - repo: https://github.com/gitleaks/gitleaks\n    rev: v8.30.1\n    hooks:\n      - id: gitleaks\n"] %}{% endif %}
{% if answers.include_ci and answers.github_actions %}{% set ns.b = ns.b + ["  - repo: https://github.com/Mateusz-Grzelinski/actionlint-py\n    rev: v1.7.12.24\n    hooks:\n      - id: actionlint\n        files: ^\\.github/workflows/\n"] %}{% endif %}
{% set _pc = {"python": "  - repo: https://github.com/astral-sh/ruff-pre-commit\n    rev: v0.15.17\n    hooks:\n      - id: ruff-check\n        args: [--fix]\n      - id: ruff-format\n  - repo: https://github.com/pre-commit/mirrors-mypy\n    rev: v2.1.0\n    hooks:\n      - id: mypy\n", "node": "  - repo: local\n    hooks:\n      - id: prettier\n        name: prettier\n        entry: npx prettier --write\n        language: system\n        files: \\.(js|jsx|mjs|cjs|ts|tsx|json|css|md)$\n      - id: eslint\n        name: eslint\n        entry: npx eslint --fix\n        language: system\n        files: \\.(js|jsx|mjs|cjs|ts|tsx)$\n", "go": "  - repo: local\n    hooks:\n      - id: gofmt\n        name: gofmt\n        entry: gofmt -w\n        language: system\n        files: \\.go$\n      - id: golangci-lint\n        name: golangci-lint\n        entry: golangci-lint run\n        language: system\n        pass_filenames: false\n        types: [go]\n", "rust": "  - repo: local\n    hooks:\n      - id: cargo-fmt\n        name: cargo fmt\n        entry: cargo fmt --\n        language: system\n        files: \\.rs$\n      - id: clippy\n        name: cargo clippy\n        entry: cargo clippy -- -D warnings\n        language: system\n        pass_filenames: false\n        types: [rust]\n", "html": "  - repo: https://github.com/Lucas-C/pre-commit-hooks-nodejs\n    rev: v1.1.2\n    hooks:\n      - id: htmlhint\n  - repo: https://github.com/lycheeverse/lychee.git\n    rev: lychee-v0.24.2\n    hooks:\n      - id: lychee\n        args: [--offline, --no-progress]\n"} %}
{% for _l in answers.languages %}{% if _l in _pc %}{% set ns.b = ns.b + [_pc[_l]] %}{% endif %}{% endfor %}
{% if answers.include_docs and "python" not in answers.languages %}{% set ns.b = ns.b + ["  - repo: https://github.com/astral-sh/ruff-pre-commit\n    rev: v0.15.17\n    hooks:\n      - id: ruff-check\n        args: [--fix]\n        files: ^tools/.*\\.py$\n      - id: ruff-format\n        files: ^tools/.*\\.py$\n"] %}{% endif %}
{% if answers.include_docs %}{% set ns.b = ns.b + ["  - repo: local\n    hooks:\n      - id: rfc-status\n        name: rfc status -> folder sync\n        entry: python3 tools/checks/sync_rfc_status.py\n        language: system\n        pass_filenames: false\n        files: ^docs/rfc/.*\\.md$\n"] %}{% endif %}
{% if _rfc_gate %}{% set ns.b = ns.b + ["  - repo: local\n    hooks:\n      - id: rfc-needed\n        name: RFC needed for structural changes\n        entry: python3 tools/checks/rfc_needed.py\n        language: system\n        stages: [commit-msg]\n"] %}{% endif %}
{% if _py_gates %}{% set ns.b = ns.b + ["  - repo: local\n    hooks:\n      - id: docs-sync\n        name: architecture docs for new components\n        entry: python3 tools/checks/docs_sync.py\n        language: system\n        stages: [commit-msg]\n      - id: tests-needed\n        name: tests accompany code changes\n        entry: python3 tools/checks/tests_needed.py\n        language: system\n        stages: [commit-msg]\n"] %}{% endif %}
{% set _th = {"python": "  - repo: local\n    hooks:\n      - id: python-tests\n        name: Python tests (pre-push)\n        entry: env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE pytest\n        language: system\n        pass_filenames: false\n        always_run: true\n        stages: [pre-push]\n", "node": "  - repo: local\n    hooks:\n      - id: node-tests\n        name: JavaScript / TypeScript tests (pre-push)\n        entry: env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE npm test --if-present\n        language: system\n        pass_filenames: false\n        always_run: true\n        stages: [pre-push]\n", "go": "  - repo: local\n    hooks:\n      - id: go-tests\n        name: Go tests (pre-push)\n        entry: env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE go test ./...\n        language: system\n        pass_filenames: false\n        always_run: true\n        stages: [pre-push]\n", "rust": "  - repo: local\n    hooks:\n      - id: rust-tests\n        name: Rust tests (pre-push)\n        entry: env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE cargo test\n        language: system\n        pass_filenames: false\n        always_run: true\n        stages: [pre-push]\n"} %}
{% for _l in answers.languages %}{% if _l in _th %}{% set ns.b = ns.b + [_th[_l]] %}{% endif %}{% endfor %}
{% if answers.include_docs %}{% set ns.b = ns.b + ["  - repo: local\n    hooks:\n      - id: tools-checks-tests\n        name: tools/checks tests (pre-push)\n        entry: env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE python3 -m unittest discover -s tools/checks\n        language: system\n        pass_filenames: false\n        always_run: true\n        stages: [pre-push]\n"] %}{% endif %}
{% set _stages = "pre-commit, commit-msg, pre-push" if (_rfc_gate or _py_gates) else "pre-commit, pre-push" %}
default_install_hook_types: [{{ _stages }}]

repos:
{{ ns.b | join("") }}{% endif %}