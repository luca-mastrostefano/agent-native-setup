{% if ("python" in answers.languages or "node" in answers.languages or "go" in answers.languages or "rust" in answers.languages) %}{% set ns.qc = ns.qc + [("run tests", _verb ~ " test")] %}{% endif %}
{% set ns.qc = ns.qc + [("full local gate", _verb ~ " quality")] %}
{% if answers.include_docs %}{% set ns.qc = ns.qc + [("sync RFCs to their Status folder", _verb ~ " rfc-sync"), ("log an idea in docs/improvements.md", "make improvement TEXT=\"<idea>\"" if _verb == "make" else "task improvement -- \"<idea>\"")] %}{% endif %}
{% set surface_note = "Run `task --list` for the full, current set." if _verb == "task" else "Run `make help` for the full, current set." %}
{% else %}{% set surface_note = "" %}{% endif %}
