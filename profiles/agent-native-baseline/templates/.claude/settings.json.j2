{% if answers.include_agents and "claude" in answers.tools %}
{% set _q = answers.include_quality %}
{% set _allow = ([("Bash(" ~ answers.runner ~ ":*)") if (_q and not env.existing_runner) else ""] | select | list) + (["Bash(pre-commit:*)"] if (_q and answers.hooks) else []) + ["Bash(git status:*)", "Bash(git diff:*)", "Bash(git log:*)", "Bash(git show:*)"] %}
{% set _list_cmd = "command -v task >/dev/null 2>&1 && task --list || { echo 'task not found (install go-task: https://taskfile.dev) - targets from the Taskfile:'; for f in Taskfile.yml taskfile.yml Taskfile.yaml taskfile.yaml; do if [ -f \"$f\" ]; then cat \"$f\"; break; fi; done | sed -n -E 's/^  ([A-Za-z0-9_.-]+):$/\\1/p; s/^    desc: */  /p'; }" if answers.runner == "task" else ("grep -E '^[A-Za-z0-9_.-]+:.*## ' Makefile | sed -E 's/:.*## /  /' || grep -E '^[A-Za-z0-9_.-]+:' Makefile | cut -d: -f1 | sort -u" if env.existing_runner else "command -v make >/dev/null 2>&1 && make help || echo 'make not found on PATH'") %}
{% set _sess = ([{"type": "command", "command": _list_cmd}] if (_q or env.existing_runner) else []) + [{"type": "command", "command": "command -v agent-native-setup >/dev/null 2>&1 && agent-native-setup update --check 2>/dev/null || true"}] %}
{% if answers.include_agents and "claude" in answers.tools and answers.include_quality and answers.include_docs and ("python" in answers.languages or "node" in answers.languages or "go" in answers.languages or "rust" in answers.languages) %}{% set _hooks = {"SessionStart": [{"hooks": _sess}], "PostToolUse": [{"matcher": "Edit|Write", "hooks": [{"type": "command", "command": "python3 tools/checks/format_on_edit.py"}]}]} %}{% else %}{% set _hooks = {"SessionStart": [{"hooks": _sess}]} %}{% endif %}
{% set _settings = {"permissions": {"allow": _allow}, "hooks": _hooks} %}
{{ _settings | to_json }}
{% endif %}